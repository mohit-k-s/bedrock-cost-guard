  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.772.0",
    "@aws-sdk/client-dynamodb": "^3.772.0",
    "@aws-sdk/lib-dynamodb": "^3.772.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.3",
    "vitest": "^2.1.8"
  }
}
